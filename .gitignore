# ---- Secrets ----
# Never commit real credentials. Copy .env.example to .env and add your key there.
.env
.env.*
!.env.example

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipython/

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- Generated eval artifacts ----
# The prompt-eval notebooks (006-008) regenerate these on every run, so they are
# transient outputs rather than source. Keep them out of version control.
dataset.json
output.json
output.html

# ---- Text editor tool sandbox (011) ----
# Claude creates and edits files here when running the text editor notebook,
# so its contents are regenerated on every run.
editor_workspace/

# ---- OS / editor / tooling noise ----
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/settings.local.json